{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "internal": {
      "extends": "development"
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "medium"
      }
    },
    "production": {
      "autoIncrement": true
    }
  }
}
